{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Alert/**",
              "components/Button/**",
              "components/Checklist/**",
              "components/Chip/**",
              "components/HeroRadar/**",
              "components/Input/**",
              "components/Nav/**",
              "components/Pass/**",
              "components/Row/**",
              "components/SegmentedControl/**",
              "components/Skeleton/**",
              "design_handoff_discover/design-system/**",
              "ds-preview.js"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Onest))/i]",
        "message": "Font not provided by the design system. Available: Onest."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: children, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|disabled|type|onClick|icon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, disabled, type, onClick, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ink|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ink' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|done|key|ref|className|style|children)$/]",
        "message": "<ChecklistItem> doesn't accept that prop. Declared props: label, done."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|category|active|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, category, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:airport|seguro|viagem|cashback|compras|pontos)$/]",
        "message": "<Chip> category must be one of 'airport' | 'seguro' | 'viagem' | 'cashback' | 'compras' | 'pontos'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroRadar'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|value|label|caption|key|ref|className|style|children)$/]",
        "message": "<HeroRadar> doesn't accept that prop. Declared props: count, value, label, caption."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|placeholder|value|onChange|icon|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, placeholder, value, onChange, icon, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|href|active|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: label, icon, href, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pass'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|via|desc|category|tag|isNew|originType|originLabel|href|onClick|key|ref|className|style|children)$/]",
        "message": "<Pass> doesn't accept that prop. Declared props: title, via, desc, category, tag, isNew, originType, originLabel, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pass'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:airport|seguro|viagem|cashback|compras|pontos)$/]",
        "message": "<Pass> category must be one of 'airport' | 'seguro' | 'viagem' | 'cashback' | 'compras' | 'pontos'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pass'] > JSXAttribute[name.name='originType'] > Literal[value!=/^(?:emissor|bandeira|parceiro)$/]",
        "message": "<Pass> originType must be one of 'emissor' | 'bandeira' | 'parceiro'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Row'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|leading|trailing|href|onClick|key|ref|className|style|children)$/]",
        "message": "<Row> doesn't accept that prop. Declared props: children, leading, trailing, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|width|height|radius|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: variant, width, height, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:bar|pass)$/]",
        "message": "<Skeleton> variant must be one of 'bar' | 'pass'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Alert": {
        "replaces": []
